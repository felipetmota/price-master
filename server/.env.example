# SQL Server connection
SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=PriceManagement
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=ChangeMe!

# TLS / encryption (set ENCRYPT=true for Azure SQL or production with valid certs)
SQLSERVER_ENCRYPT=false
SQLSERVER_TRUST_CERT=true

# API
PORT=3001
# Comma-separated list of origins allowed to call this API.
# Use * during development; lock down in production.
CORS_ORIGIN=*