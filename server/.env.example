# SQLite database file location.
# Defaults to ./data/prices.db (relative to the server working directory).
# In Docker the recommended path is /data/prices.db with a mounted volume.
SQLITE_PATH=./data/prices.db

# API
PORT=3001
# Comma-separated list of origins allowed to call this API.
# Use * during development; lock down in production.
CORS_ORIGIN=*