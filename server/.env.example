# PostgreSQL connection
# You can use either DATABASE_URL...
DATABASE_URL=postgres://price_user:ChangeMe@postgres:5432/price_management

# ...or the individual variables below (DATABASE_URL takes precedence if set):
PGHOST=postgres
PGPORT=5432
PGDATABASE=price_management
PGUSER=price_user
PGPASSWORD=ChangeMe

# Set to "true" to require TLS to the database
PGSSL=false

# API
PORT=3001
# Comma-separated list of origins allowed to call this API.
# Use * during development; lock down in production.
CORS_ORIGIN=*